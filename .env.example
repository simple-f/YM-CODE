# .env.example - YM-CODE 环境配置模板
# 复制此文件为 .env 并填写实际配置

# ============================================================
# LLM API 配置（必需 - 至少配置一个）
# ============================================================

# 阿里云百炼（推荐，支持通义千问、GLM 等）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# OpenAI（可选）
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 月之暗面 Moonshot（可选）
# MOONSHOT_API_KEY=sk-your-moonshot-key-here

# 智谱 AI（可选）
# ZHIPU_API_KEY=your-zhipu-key-here


# ============================================================
# YM-CODE 核心配置
# ============================================================

# 最大迭代次数（Agent 循环上限）
YM_CODE_MAX_ITERATIONS=30

# 超时时间（秒）
YM_CODE_TIMEOUT=300

# 日志级别（DEBUG/INFO/WARNING/ERROR）
YM_CODE_LOG_LEVEL=INFO

# 是否启用自我提升功能
YM_CODE_SELF_IMPROVE=true


# ============================================================
# 服务器配置
# ============================================================

# 监听地址
YM_CODE_HOST=0.0.0.0

# 监听端口
YM_CODE_PORT=18770

# 调试模式（开发时启用）
YM_CODE_DEBUG=false

# 是否启用 CORS（跨域）
YM_CODE_CORS_ENABLE=true


# ============================================================
# 存储配置
# ============================================================

# Session 数据库路径
YM_CODE_SESSIONS_DB=~/.ymcode/sessions.db

# 记忆存储目录
YM_CODE_MEMORY_DIR=~/.ymcode/memory

# 日志目录
YM_CODE_LOGS_DIR=~/.ymcode/logs


# ============================================================
# 功能开关
# ============================================================

# 文件浏览器
YM_CODE_FEATURE_FILE_BROWSER=true

# Web 终端
YM_CODE_FEATURE_WEB_TERMINAL=true

# 任务管理
YM_CODE_FEATURE_TASK_MANAGER=true

# 技能市场
YM_CODE_FEATURE_SKILLS_MARKET=true


# ============================================================
# MCP 配置（可选）
# ============================================================

# 是否启用 MCP 协议
YM_CODE_MCP_ENABLE=true

# MCP 服务器列表（逗号分隔）
# YM_CODE_MCP_SERVERS=filesystem,git,database


# ============================================================
# 其他配置
# ============================================================

# Python 编码（Windows 建议设置）
PYTHONIOENCODING=utf-8

# 控制台颜色支持
FORCE_COLOR=true
