{
  "name": "ymcode",
  "displayName": "YM-CODE AI Assistant",
  "description": "YM-CODE AI 编程助手 - 代码分析、格式化、智能建议",
  "version": "0.8.0",
  "publisher": "ymcode",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ymcode.analyze",
        "title": "YM-CODE: 分析当前文件"
      },
      {
        "command": "ymcode.format",
        "title": "YM-CODE: 格式化当前文件"
      },
      {
        "command": "ymcode.check",
        "title": "YM-CODE: 检查代码问题"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "ymcode.analyze",
          "group": "ymcode@1"
        },
        {
          "when": "editorHasSelection",
          "command": "ymcode.format",
          "group": "ymcode@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0"
  }
}
