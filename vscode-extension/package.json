{
  "name": "ym-code",
  "displayName": "YM-CODE - AI Programming Assistant",
  "description": "下一代 AI 编程助手，全面对标 Claude Code",
  "version": "0.1.0",
  "publisher": "ym-code",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ym-code.ask",
        "title": "YM-CODE: Ask AI"
      },
      {
        "command": "ym-code.explain",
        "title": "YM-CODE: Explain Code"
      },
      {
        "command": "ym-code.refactor",
        "title": "YM-CODE: Refactor Code"
      },
      {
        "command": "ym-code.debug",
        "title": "YM-CODE: Debug Code"
      },
      {
        "command": "ym-code.test",
        "title": "YM-CODE: Generate Tests"
      },
      {
        "command": "ym-code.review",
        "title": "YM-CODE: Code Review"
      },
      {
        "command": "ym-code.showPanel",
        "title": "YM-CODE: Show Panel"
      },
      {
        "command": "ym-code.clearHistory",
        "title": "YM-CODE: Clear History"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "ym-code.explain",
          "group": "ym-code@1"
        },
        {
          "when": "editorHasSelection",
          "command": "ym-code.refactor",
          "group": "ym-code@2"
        },
        {
          "when": "editorHasSelection",
          "command": "ym-code.debug",
          "group": "ym-code@3"
        }
      ],
      "explorer/context": [
        {
          "command": "ym-code.review",
          "group": "ym-code@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ym-code-sidebar",
          "title": "YM-CODE",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ym-code-sidebar": [
        {
          "type": "webview",
          "id": "ym-code.mainPanel",
          "name": "YM-CODE Assistant"
        }
      ]
    },
    "configuration": {
      "title": "YM-CODE",
      "properties": {
        "ym-code.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "YM-CODE API 端点"
        },
        "ym-code.model": {
          "type": "string",
          "default": "qwen3.5-plus",
          "description": "使用的 AI 模型"
        },
        "ym-code.maxTokens": {
          "type": "number",
          "default": 4000,
          "description": "最大 Token 数"
        },
        "ym-code.theme": {
          "type": "string",
          "enum": ["auto", "light", "dark"],
          "default": "auto",
          "description": "主题设置"
        }
      }
    },
    "keybindings": [
      {
        "command": "ym-code.ask",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y",
        "when": "editorTextFocus"
      },
      {
        "command": "ym-code.showPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.0.0"
  }
}
